---
import BaseLayout from "../layouts/Layout.astro";
import CourseCard from "../components/courseCard.astro";
import courses from "../data/courses.json";
---

<BaseLayout>
  <h1 class="text-3xl font-bold px-4 py-8">Unsere Kurse</h1>

  <div class="grid gap-6 px-4 pb-12 sm:grid-cols-2 lg:grid-cols-3">
    {courses.map(course => (
      <CourseCard {...course} />
    ))}
  </div>
</BaseLayout>
