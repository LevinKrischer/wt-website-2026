---
const navItems = [
    { href: "/", label: "Start" },
    { href: "/kurse", label: "Kurse" },
    { href: "/ueber-uns", label: "Ueber uns" },
    { href: "/kontakt", label: "Kontakt" },
];

const normalizePath = (path: string) => {
    if (path.length > 1 && path.endsWith("/")) return path.slice(0, -1);
    return path;
};

const currentPath = normalizePath(Astro.url.pathname);
const isActive = (href: string) => normalizePath(href) === currentPath;
---

<header class="sticky top-0 z-40 border-b border-brand-gray-200 bg-white/95 backdrop-blur">
    <nav class="mx-auto grid max-w-6xl grid-cols-[1fr_auto] items-center gap-4 px-4 py-3 md:grid-cols-[1fr_auto_1fr]" aria-label="Hauptnavigation">
        <a href="/" class="inline-flex items-center gap-3 rounded-md px-2 py-1 transition hover:bg-brand-gray-100">
            <span class="inline-flex h-9 w-9 items-center justify-center rounded-md border border-dashed border-brand-primary/40 bg-brand-primary/5 text-meta font-semibold text-brand-primary">Logo</span>
            <span class="text-lg font-semibold text-brand-gray-800">Wir tanzen</span>
        </a>

        <ul class="hidden items-center justify-center gap-7 md:flex">
            {navItems.map((item) => (
                <li>
                    <a
                        href={item.href}
                        class={`relative font-medium transition after:absolute after:-bottom-1 after:left-0 after:h-0.5 after:rounded-full after:bg-brand-primary after:transition-all after:duration-300 ${
                            isActive(item.href)
                                ? "text-brand-primary after:w-full"
                                : "text-brand-gray-700 after:w-0 hover:text-brand-accent hover:after:w-full"
                        }`}
                        aria-current={isActive(item.href) ? "page" : undefined}
                    >
                        {item.label}
                    </a>
                </li>
            ))}
        </ul>

        <div class="ml-auto flex items-center gap-2 md:gap-3">
            <a
                href="/wochenplan"
                class={`hidden rounded-md px-4 py-2 font-medium text-white transition hover:shadow md:inline-flex ${
                    isActive("/wochenplan")
                        ? "bg-brand-primary-dark"
                        : "bg-brand-primary hover:bg-brand-primary-dark"
                }`}
                aria-current={isActive("/wochenplan") ? "page" : undefined}
            >
                Wochenplan
            </a>

            <button id="mobile-menu-toggle" type="button" class="inline-flex h-10 w-10 items-center justify-center rounded-md border border-brand-gray-300 text-brand-gray-700 transition hover:border-brand-primary hover:text-brand-primary md:hidden" aria-controls="mobile-menu" aria-expanded="false" aria-label="Menue oeffnen">
                <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                    <path d="M4 7H20" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                    <path d="M4 12H20" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                    <path d="M4 17H20" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                </svg>
            </button>
        </div>
    </nav>

    <div id="mobile-overlay" class="pointer-events-none fixed inset-0 z-40 bg-brand-gray-900/40 opacity-0 transition duration-300 md:hidden"></div>

    <aside id="mobile-menu" class="pointer-events-none fixed right-0 top-0 z-50 flex h-dvh w-80 max-w-[86vw] translate-x-full flex-col border-l border-brand-gray-200 bg-white p-5 shadow-lg transition duration-300 md:hidden" aria-hidden="true">
        <div class="mb-8 flex items-center justify-between">
            <span class="text-h3 font-semibold text-brand-gray-800">Menue</span>
            <button id="mobile-menu-close" type="button" class="inline-flex h-9 w-9 items-center justify-center rounded-md border border-brand-gray-300 text-brand-gray-700 transition hover:border-brand-primary hover:text-brand-primary" aria-label="Menue schliessen">
                <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                    <path d="M6 6L18 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                    <path d="M18 6L6 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                </svg>
            </button>
        </div>

        <ul class="flex flex-col gap-2">
            {navItems.map((item) => (
                <li>
                    <a
                        href={item.href}
                        class={`mobile-link block rounded-md px-3 py-2 font-medium transition ${
                            isActive(item.href)
                                ? "bg-brand-primary/10 text-brand-primary"
                                : "text-brand-gray-700 hover:bg-brand-gray-100 hover:text-brand-primary"
                        }`}
                        aria-current={isActive(item.href) ? "page" : undefined}
                    >
                        {item.label}
                    </a>
                </li>
            ))}
        </ul>

        <a
            href="/wochenplan"
            class={`mt-auto inline-flex items-center justify-center rounded-md px-4 py-3 font-medium text-white transition ${
                isActive("/wochenplan")
                    ? "bg-brand-primary-dark"
                    : "bg-brand-primary hover:bg-brand-primary-dark"
            }`}
            aria-current={isActive("/wochenplan") ? "page" : undefined}
        >
            Zum Wochenplan
        </a>
    </aside>
</header>

<script>
    const toggle = document.getElementById("mobile-menu-toggle");
    const closeBtn = document.getElementById("mobile-menu-close");
    const menu = document.getElementById("mobile-menu");
    const overlay = document.getElementById("mobile-overlay");
    const links = document.querySelectorAll(".mobile-link");

    if (toggle && closeBtn && menu && overlay) {
        const openMenu = () => {
            menu.classList.remove("translate-x-full", "pointer-events-none");
            overlay.classList.remove("opacity-0", "pointer-events-none");
            overlay.classList.add("pointer-events-auto");
            toggle.setAttribute("aria-expanded", "true");
            menu.setAttribute("aria-hidden", "false");
            document.body.classList.add("overflow-hidden");
        };

        const closeMenu = () => {
            menu.classList.add("translate-x-full", "pointer-events-none");
            overlay.classList.add("opacity-0", "pointer-events-none");
            overlay.classList.remove("pointer-events-auto");
            toggle.setAttribute("aria-expanded", "false");
            menu.setAttribute("aria-hidden", "true");
            document.body.classList.remove("overflow-hidden");
        };

        toggle.addEventListener("click", openMenu);
        closeBtn.addEventListener("click", closeMenu);
        overlay.addEventListener("click", closeMenu);
        links.forEach((link) => link.addEventListener("click", closeMenu));
        window.addEventListener("resize", () => {
            if (window.innerWidth >= 768) closeMenu();
        });
    }
</script>
